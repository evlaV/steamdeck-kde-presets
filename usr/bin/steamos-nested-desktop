#!/bin/sh

set -eu

# Check if we're running in desktop mode, or nested-in-nested
if [ "$XDG_SESSION_DESKTOP" = "KDE" ] || [ "${KDE_FULL_SESSION-}" = "true" ]; then
    echo "steamos-nested-desktop: refusing to launch in KDE"
    if [ ! -t 1 ]; then # no stdout, not in terminal
        kdialog --title "Nested Desktop" --sorry "Nested desktop should be launched in game mode, and can be added to Steam via the 'Add to Steam' menu option."
    fi
    exit 0
fi

# Remove the performance overlay, it meddles with some tasks
unset LD_PRELOAD

# Undo gamescope's session startup script that sets XDG_DESKTOP_PORTAL_DIR
# to ensure xdg-desktop-portal doesn't try to start desktop portals
unset XDG_DESKTOP_PORTAL_DIR

# Create a new XDG_RUNTIME_DIR
NEW_XDG_RUNTIME_DIR=$(mktemp -d "$XDG_RUNTIME_DIR/nested-desktop.XXXXXXXX") # is 0700

cleanup()
{
    echo "steamos-nested-desktop: cleaning up $NEW_XDG_RUNTIME_DIR"
    rm -Rf --one-file-system "$NEW_XDG_RUNTIME_DIR" || true
}
trap cleanup EXIT

# Some things are (currently) shared, pulseaudio socket needs to be
# connected to the main session
mkdir "$NEW_XDG_RUNTIME_DIR"/pulse --mode 0700
ln -s "$XDG_RUNTIME_DIR"/pulse/native "$NEW_XDG_RUNTIME_DIR"/pulse/native
ln -s "$XDG_RUNTIME_DIR"/pipewire* "$NEW_XDG_RUNTIME_DIR"/.

# Shadow kwin_wayland_wrapper so that we can pass args to kwin wrapper
# whilst being launched by plasma-session
mkdir "$NEW_XDG_RUNTIME_DIR"/bin
cat <<EOF > "$NEW_XDG_RUNTIME_DIR"/bin/kwin_wayland_wrapper
#!/bin/sh
/usr/bin/kwin_wayland_wrapper --fullscreen true --no-lockscreen \$@
EOF
chmod a+x "$NEW_XDG_RUNTIME_DIR"/bin/kwin_wayland_wrapper
export PATH="$NEW_XDG_RUNTIME_DIR"/bin:"$PATH"

# Start session
export XDG_RUNTIME_DIR="$NEW_XDG_RUNTIME_DIR"

echo "steamos-nested-desktop: starting session"
dbus-run-session startplasma-wayland
